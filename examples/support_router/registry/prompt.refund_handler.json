{
  "id": "prompt.refund_handler",
  "type": "prompt",
  "version": "1.0.0",
  "extends": "base.support_agent",
  "inputs": {
    "intent": { "type": "string" },
    "user_id": { "type": "string" },
    "query": { "type": "string" }
  },
  "messages": [
    {
      "role": "user",
      "content": "The user {{user_id}} is requesting a refund. Draft a polite policy-abiding response regarding: {{query}}"
    }
  ],
  "config": {
    "temperature": 0.7,
    "max_tokens": 150
  }
}
